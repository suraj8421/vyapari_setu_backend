// ============================================
// Vyaparisetu - Database Schema (Prisma v7)
// Inventory & Ledger Management System
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTHENTICATION & AUTHORIZATION
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  STORE_USER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  role          UserRole  @default(STORE_USER)
  isActive      Boolean   @default(true) @map("is_active")
  refreshToken  String?   @map("refresh_token")

  // Relations
  storeId       String?   @map("store_id")
  store         Store?    @relation(fields: [storeId], references: [id])

  sales         Sale[]
  purchases     Purchase[]
  ledgerEntries LedgerEntry[]
  expenses      Expense[]
  
  // Audit Logs Relations
  changesMade      AuditLog[] @relation("ChangesMade")
  changesApproved  AuditLog[] @relation("ChangesApproved")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([storeId])
  @@map("users")
}

// ─────────────────────────────────────────────
// STORE MANAGEMENT
// ─────────────────────────────────────────────

model Store {
  id          String   @id @default(uuid())
  name        String
  address     String?
  city        String?
  state       String?
  pincode     String?
  phone       String?
  gstNumber   String?  @map("gst_number")
  isActive    Boolean  @default(true) @map("is_active")

  // Relations
  users       User[]
  products    Product[]
  inventory   Inventory[]
  sales       Sale[]
  purchases   Purchase[]
  customers   Customer[]
  suppliers   Supplier[]
  expenses    Expense[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("stores")
}

// ─────────────────────────────────────────────
// PRODUCT & INVENTORY
// ─────────────────────────────────────────────

model Product {
  id            String   @id @default(uuid())
  name          String
  description   String?
  sku           String   @unique
  barcode       String?  @unique
  category      String?
  unit          String   @default("pcs") // pcs, kg, ltr, box, etc.
  costPrice     Decimal  @map("cost_price") @db.Decimal(12, 2)
  sellingPrice  Decimal  @map("selling_price") @db.Decimal(12, 2)
  gstRate       Decimal  @default(0) @map("gst_rate") @db.Decimal(5, 2) // percentage
  hsnCode       String?  @map("hsn_code")
  isActive      Boolean  @default(true) @map("is_active")

  // Relations
  storeId       String   @map("store_id")
  store         Store    @relation(fields: [storeId], references: [id])

  inventory     Inventory[]
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([sku])
  @@index([barcode])
  @@index([storeId])
  @@index([category])
  @@index([name])
  @@map("products")
}

model Inventory {
  id              String    @id @default(uuid())
  quantity        Int       @default(0)
  minStockLevel   Int       @default(10) @map("min_stock_level")
  maxStockLevel   Int?      @map("max_stock_level")
  batchNumber     String?   @map("batch_number")
  expiryDate      DateTime? @map("expiry_date")
  location        String?   // shelf location in store
  
  // Granular Tracking
  boxCount        Int?      @map("box_count")
  unitsPerBox     Int?      @map("units_per_box")

  // Relations
  productId       String    @map("product_id")
  product         Product   @relation(fields: [productId], references: [id])

  storeId         String    @map("store_id")
  store           Store     @relation(fields: [storeId], references: [id])
  
  saleItems       SaleItem[]

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([productId, storeId, batchNumber])
  @@index([productId])
  @@index([storeId])
  @@index([quantity])
  @@map("inventory")
}

// ─────────────────────────────────────────────
// CUSTOMERS & KHATA (LEDGER)
// ─────────────────────────────────────────────

model Customer {
  id            String   @id @default(uuid())
  name          String
  phone         String?
  email         String?
  address       String?
  gstNumber     String?  @map("gst_number")
  creditLimit   Decimal  @default(0) @map("credit_limit") @db.Decimal(12, 2)
  balance       Decimal  @default(0) @db.Decimal(12, 2) // positive = customer owes, negative = overpaid
  isActive      Boolean  @default(true) @map("is_active")
  isWalkIn      Boolean  @default(false) @map("is_walk_in")

  // Relations
  storeId       String   @map("store_id")
  store         Store    @relation(fields: [storeId], references: [id])

  sales         Sale[]
  ledgerEntries LedgerEntry[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([phone])
  @@index([name])
  @@index([storeId])
  @@index([storeId, isWalkIn])
  @@map("customers")
}

enum LedgerType {
  CREDIT  // customer owes (sale on credit)
  DEBIT   // customer paid
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CREDIT
  OTHER
}

model LedgerEntry {
  id              String        @id @default(uuid())
  type            LedgerType
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(CASH) @map("payment_method")
  description     String?
  reference       String?       // reference number / transaction ID
  balanceAfter    Decimal       @map("balance_after") @db.Decimal(12, 2)

  // Relations
  customerId      String        @map("customer_id")
  customer        Customer      @relation(fields: [customerId], references: [id])

  saleId          String?       @map("sale_id")
  sale            Sale?         @relation(fields: [saleId], references: [id])

  recordedById    String        @map("recorded_by_id")
  recordedBy      User          @relation(fields: [recordedById], references: [id])

  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([customerId])
  @@index([saleId])
  @@index([createdAt])
  @@map("ledger_entries")
}

// ─────────────────────────────────────────────
// SALES
// ─────────────────────────────────────────────

enum SaleStatus {
  COMPLETED
  RETURNED
  PARTIAL_RETURN
}

model Sale {
  id              String       @id @default(uuid())
  invoiceNumber   String       @unique @map("invoice_number")
  subtotal        Decimal      @db.Decimal(12, 2)
  taxAmount       Decimal      @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discount        Decimal      @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal      @map("total_amount") @db.Decimal(12, 2)
  paidAmount      Decimal      @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(CASH) @map("payment_method")
  status          SaleStatus   @default(COMPLETED)
  notes           String?
  
  // New Fields for Unified Entry
  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  subCategory          String?   @map("sub_category")
  isApproved           Boolean   @default(true) @map("is_approved")

  // Relations
  storeId         String       @map("store_id")
  store           Store        @relation(fields: [storeId], references: [id])

  customerId      String?      @map("customer_id")
  customer        Customer?    @relation(fields: [customerId], references: [id])

  soldById        String       @map("sold_by_id")
  soldBy          User         @relation(fields: [soldById], references: [id])

  items           SaleItem[]
  ledgerEntries   LedgerEntry[]

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([invoiceNumber])
  @@index([storeId])
  @@index([customerId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id          String  @id @default(uuid())
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  gstRate     Decimal @default(0) @map("gst_rate") @db.Decimal(5, 2)
  gstAmount   Decimal @default(0) @map("gst_amount") @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  // Relations
  saleId      String  @map("sale_id")
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  
  // Batch Tracking
  sourceInventoryId String? @map("source_inventory_id")
  sourceInventory   Inventory? @relation(fields: [sourceInventoryId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

// ─────────────────────────────────────────────
// PURCHASES & SUPPLIERS
// ─────────────────────────────────────────────

model Supplier {
  id          String   @id @default(uuid())
  name        String
  phone       String?
  email       String?
  address     String?
  gstNumber   String?  @map("gst_number")
  isActive    Boolean  @default(true) @map("is_active")

  // Relations
  storeId     String   @map("store_id")
  store       Store    @relation(fields: [storeId], references: [id])

  purchases   Purchase[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@index([storeId])
  @@map("suppliers")
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  PARTIAL
  CANCELLED
}

model Purchase {
  id              String         @id @default(uuid())
  invoiceNumber   String?        @map("invoice_number")
  subtotal        Decimal        @db.Decimal(12, 2)
  taxAmount       Decimal        @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount     Decimal        @map("total_amount") @db.Decimal(12, 2)
  paidAmount      Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status          PurchaseStatus @default(PENDING)
  notes           String?
  
  // New Fields for Unified Entry
  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  subCategory          String?   @map("sub_category")
  isApproved           Boolean   @default(true) @map("is_approved")

  // Relations
  storeId         String         @map("store_id")
  store           Store          @relation(fields: [storeId], references: [id])

  supplierId      String         @map("supplier_id")
  supplier        Supplier       @relation(fields: [supplierId], references: [id])

  createdById     String         @map("created_by_id")
  createdBy       User           @relation(fields: [createdById], references: [id])

  items           PurchaseItem[]

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([storeId])
  @@index([supplierId])
  @@index([createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id          String  @id @default(uuid())
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  gstRate     Decimal @default(0) @map("gst_rate") @db.Decimal(5, 2)
  gstAmount   Decimal @default(0) @map("gst_amount") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  // Relations
  purchaseId  String   @map("purchase_id")
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

// ─────────────────────────────────────────────
// EXPENSES & AUDIT
// ─────────────────────────────────────────────

model Expense {
  id            String    @id @default(uuid())
  category      String
  amount        Decimal   @db.Decimal(12, 2)
  date          DateTime  @default(now())
  description   String?
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  
  storeId       String    @map("store_id")
  store         Store     @relation(fields: [storeId], references: [id])
  
  recordedById  String    @map("recorded_by_id")
  recordedBy    User      @relation(fields: [recordedById], references: [id])

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("expenses")
}

enum LogStatus {
  PENDING
  APPROVED
  REJECTED
}

model AuditLog {
  id            String    @id @default(uuid())
  entityType    String    // SALE, PURCHASE, etc.
  entityId      String
  action        String    // CREATE, UPDATE, DELETE
  oldValue      Json?     @map("old_value")
  newValue      Json?     @map("new_value")
  
  changedById   String    @map("changed_by_id")
  changedBy     User      @relation("ChangesMade", fields: [changedById], references: [id])
  
  approvedById  String?   @map("approved_by_id")
  approvedBy    User?     @relation("ChangesApproved", fields: [approvedById], references: [id])
  
  status        LogStatus @default(PENDING)
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("audit_logs")
}
